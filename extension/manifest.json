{
  "manifest_version": 3,
  "name": "Privora Shield",
  "version": "1.1.0",
  "description": "Continuous digital privacy and reputation intelligence monitor.",
  "permissions": ["activeTab", "tabs", "storage"],
  "host_permissions": ["*://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
